<!doctype html>
<html lang="{{ site.lang }}">
  <!-- Head -->
  <head>
    {% include head.liquid %}
  </head>

  <!-- Body：独立项目页，不含主站导航栏与页脚 -->
  <body class="no-navbar">
    <!-- 隐藏占位：theme.js 仍会绑定 #light-toggle，缺失会报错；主题已在加载时自动应用 -->
    <a id="light-toggle" style="display: none"></a>

    <!-- Content -->
    <div class="container mt-4 mb-5" role="main">
      <!-- 返回项目列表（唯一的导航，避免无路可回） -->
      <p class="mt-2 mb-3">
        <a href="{{ '/projects/' | relative_url }}" class="back-link">&larr; Projects</a>
      </p>

      <div class="post">
        <header class="post-header">
          <h1 class="post-title">{{ page.title }}</h1>
          {% if page.description %}
            <p class="post-description">{{ page.description }}</p>
          {% endif %}
        </header>

        <article>
          {{ content }}
        </article>
      </div>
    </div>

    <!-- JavaScripts -->
    {% include scripts/jquery.liquid %}
    {% include scripts/bootstrap.liquid %}
    {% include scripts/mathjax.liquid %}
    {% include scripts/analytics.liquid %}
    {% include scripts/imageLayouts.liquid %}
  </body>
</html>
